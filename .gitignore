# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Node / Next.js ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ─── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ─── Environment / secrets ─────────────────────────────────────────────────────
.env*
# never commit credentials — use .env at repo root, .env.local for overrides

# ─── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.venv/
venv/
osint_workers/.venv/
osint_workers/*.pid
osint_workers/*.log

# ─── ECI / historical source data ──────────────────────────────────────────────
# Large binary / copyrighted ECI election files — never commit.
# Ingestors read from this folder but the files themselves are not part of the repo.
osint_workers/historical_data/*.xlsx
osint_workers/historical_data/*.xls
osint_workers/historical_data/*.csv
osint_workers/historical_data/*.pdf
# Keep the folder itself (README / .gitkeep can live there)
!osint_workers/historical_data/.gitkeep

# Local ECI site probes / downloaded Playwright bundles
.eci*

# ─── Supabase CLI temp files ────────────────────────────────────────────────────
supabase/.temp/

# ─── Debug / one-off scripts ───────────────────────────────────────────────────
scripts/debug-*.mjs
scripts/probe-*.mjs
scripts/probe-*.py

# ─── Build / deployment ─────────────────────────────────────────────────────────
.vercel

# ─── Misc OS / editor ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Artifacts (UI screenshots, captured files) ───────────────────────────────
artifacts/
