# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Local ECI site probes / downloaded bundles (not part of the app)
.eci*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
venv/
osint_workers/.venv/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
osint_workers/*.pid
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
